# ─────────────────────────────────────────────────────────────────────────────
# apps/api — variables de entorno (ejemplo). Copia a `.env` y completa valores.
# ConfigModule carga `join(process.cwd(), '.env')`, es decir apps/api/.env.
# ─────────────────────────────────────────────────────────────────────────────

# Base de datos / cifrado
DATABASE_URL="postgresql://user:pass@localhost:5432/antigravity"
# 32 bytes utf-8 o 64 caracteres hex. SIN comillas: las comillas literales
# cuentan como caracteres (34 bytes) y producen "Invalid key length".
ENCRYPTION_KEY=64-caracteres-hex-o-32-bytes-sin-comillas
JWT_SECRET="<secreto-jwt>"

# Google Cloud (TTS usa estas credenciales globales para el check de voces)
GOOGLE_APPLICATION_CREDENTIALS="/ruta/al/service-account.json"

# 🔊 Gestor de Audios (TTS) — proveedor activo: GOOGLE (default) | ELEVENLABS
ACTIVE_TTS_PROVIDER=GOOGLE
# PoC ElevenLabs (Studio Quality). HARDCODED solo para la prueba; no se lee de la BD.
# El ElevenLabsTtsService lee EXCLUSIVAMENTE estas dos variables.
ELEVENLABS_API_KEY_POC="<elevenlabs-api-key-poc>"
ELEVENLABS_VOICE_ID_POC="<elevenlabs-voice-id-poc>"

# En modo voz (cuando el usuario escribe/habla por audio), ¿enviar TAMBIÉN el
# texto junto al audio en WhatsApp? Por defecto false: solo se envía el audio.
# Si el audio falla, el texto se envía igualmente como fallback. Pónlo en true
# para mostrar audio + texto a la vez.
SHOW_TEXT_IN_AUDIO_MODE=false

# URLs públicas
PUBLIC_API_URL="http://localhost:3001"
PUBLIC_WEB_URL="http://localhost:3000"

# Política de tratamiento de datos personales (Ley 1581 de 2012).
# Se enlaza en el resumen previo a confirmar la cita (consentimiento Habeas Data).
PRIVACY_POLICY_URL="https://www.hospitalsanvicenteanserma.gov.co/transparencia/proteccion-datos-personales"

# ─────────────────────────────────────────────────────────────────────────────
# 📡 MONITOR DE SERVICIOS (Google / Meta)
# ─────────────────────────────────────────────────────────────────────────────
# ON/OFF global del centinela de fondo (MODO A). Solo aplica al cron, no al
# monitoreo en vivo (MODO B), que se controla desde la UI.
MONITOR_ENABLED=true

# Intervalo del cron de fondo (MODO A), en minutos.
MONITOR_BG_INTERVAL_MINUTES=15

# Intervalo del monitoreo en vivo (MODO B), en segundos. Lo consume el frontend.
MONITOR_LIVE_INTERVAL_SECONDS=5

# Timeout máximo de cada check individual, en ms.
MONITOR_DEFAULT_TIMEOUT_MS=5000

# Umbral de latencia para marcar un check exitoso como DEGRADED, en ms.
MONITOR_DEGRADED_THRESHOLD_MS=3000

# Días de retención de incidentes resueltos (limpieza diaria automática 3 AM).
MONITOR_RETENTION_DAYS=365

# Nota: los checks de Gemini y Meta son por-organización. El monitor valida
# automáticamente contra la organización ACTIVA MÁS ANTIGUA; si no hay ninguna,
# esos dos checks se omiten (no generan incidentes). No requiere configuración.
# Google Cloud TTS usa GOOGLE_APPLICATION_CREDENTIALS (global).
