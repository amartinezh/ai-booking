// packages/database/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  // Identificadores Sociales (Indexados para búsqueda rápida O(1))
  facebookId String? @unique
  whatsappId String? @unique
  
  cedula    String?  @unique
  fullName  String?
  email      String?  @unique
  password   String?
  role      Role     @default(PATIENT)
  
  appointments Appointment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id          String   @id @default(uuid())
  date        DateTime
  specialty   String   // 'Medicina General' | 'Odontología'
  status      AppointmentStatus @default(SCHEDULED)
  reason      String?  
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  metaLog     Json?    
  createdAt   DateTime @default(now())
  bookedViaAi Boolean @default(false)

  // 🔒 EL CANDADO DE CONCURRENCIA: 
  // Garantiza a nivel físico en disco que no existan dos citas 
  // para la misma especialidad en la misma fecha y hora exacta.
  @@unique([date, specialty])
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}
