// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// 🏢 MULTI-TENANT: ORGANIZACIÓN (CLÍNICA/HOSPITAL)
// -----------------------------------------------------------------------------
model Organization {
  id       String  @id @default(uuid())
  name     String  @unique
  isActive Boolean @default(true)
  logoUrl  String?

  // Línea de soporte humano de la clínica. Cuando un guardrail se dispara
  // (insulto, exceso de reintentos, off-topic), el chatbot deriva al paciente
  // a este número en vez de reiniciar la sesión. Si es null, cae al reinicio.
  supportPhone String?

  // Base de Conocimiento del Chatbot (por clínica)
  knowledgeBase String? @db.Text

  // Configuración avanzada por clínica (1:1)
  settings OrganizationSettings?

  // Configuración multi-LLM por clínica (1:1) — credenciales encriptadas
  aiProviderConfig AiProviderConfig?

  // Configuración del canal WhatsApp por clínica (1:1) — credenciales encriptadas
  whatsappConfig WhatsappAccountConfig?

  // Configuración de voz/audio (TTS) por clínica (1:1) — pitch, rate, voz, codec
  audioConfig OrganizationAudioConfig?

  // Facturación Global Súper Admin
  monthlyFee      String?
  lastPaymentDate DateTime?
  autoSuspend     Boolean   @default(false)

  // Relaciones Inversas (Todo el sistema)
  users           User[]
  eps             Eps[]
  medicalServices MedicalService[]
  slots           ScheduleSlot[]
  appointments    Appointment[]
  clinicalRecords ClinicalRecord[]
  patients        PatientProfile[]
  doctors         DoctorProfile[]
  interactionLogs InteractionLog[]
  agents          AgentProfile[]
  waitlistEntries WaitlistEntry[]
  supportTickets  SupportTicket[]
  chatSurveys     ChatSurvey[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// ⚙️ CONFIGURACIONES POR ORGANIZACIÓN (extensible)
// -----------------------------------------------------------------------------
model OrganizationSettings {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Personalización del chatbot
  botName String @default("AgenIA")

  // Tolerancia a fallos del flujo conversacional:
  // máximo de reintentos por paso antes de derivar al humano.
  maxRetriesPerStep Int @default(3)

  // Tono de voz del chatbot:
  //   FORMAL    → "usted", estructurado, viñetas A/B/C explícitas
  //   INFORMAL  → "tú", conversacional, viñetas integradas en párrafo
  communicationStyle CommunicationStyle @default(FORMAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CommunicationStyle {
  FORMAL
  INFORMAL
}

// -----------------------------------------------------------------------------
// 🔊 MULTI-TENANT: CONFIGURACIÓN DE VOZ Y AUDIO (TTS) POR CLÍNICA
// Reemplaza la configuración global hardcoded del "Gestor de Audios" del
// chatbot. Cada organización define su propia voz, tono (pitch), velocidad
// (speakingRate) y códec de salida, que se inyectan dinámicamente en cada
// llamada a Google Cloud Text-to-Speech.
//
// Aislamiento NIVEL BANCA: `organizationId` es UNIQUE + FK con onDelete:Cascade.
// Una organización jamás puede leer/escribir la configuración de otra.
// Los rangos válidos de `pitch` (-20..20) y `speakingRate` (0.25..4.0) se
// imponen además con CHECK constraints en la migración SQL.
// -----------------------------------------------------------------------------
model OrganizationAudioConfig {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Códec del audio sintetizado. OGG_OPUS es el requerido por WhatsApp Cloud API.
  audioEncoding AudioEncoding @default(OGG_OPUS)

  // Tono de la voz. Rango válido de Google TTS: -20.0 a 20.0 semitonos.
  // CHECK constraint en BD: pitch BETWEEN -20.0 AND 20.0.
  pitch Float @default(0.0)

  // Velocidad de habla. Rango válido de Google TTS: 0.25x a 4.0x.
  // CHECK constraint en BD: speakingRate BETWEEN 0.25 AND 4.0.
  speakingRate Float @default(1.0)

  // Identificador de la voz de Google TTS (ej: es-US-Neural2-A).
  voiceId String @default("es-US-Neural2-A")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

// Códecs soportados por Google Cloud TTS que exponemos a las clínicas.
// OGG_OPUS es el único compatible con notas de voz de WhatsApp; MP3 y LINEAR16
// quedan disponibles para integraciones futuras (web player, telefonía).
enum AudioEncoding {
  OGG_OPUS
  MP3
  LINEAR16
}

// -----------------------------------------------------------------------------
// 🧠 MULTI-LLM: CONFIGURACIÓN DINÁMICA POR CLÍNICA
// Permite que cada clínica elija su proveedor (Gemini, ChatGPT, Claude)
// y guarde sus credenciales encriptadas (AES-256-GCM).
// -----------------------------------------------------------------------------
model AiProviderConfig {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Proveedor activo. NONE = la clínica todavía no configuró IA.
  activeProvider LlmProvider @default(NONE)

  // JSON serializado y luego encriptado con AES-256-GCM.
  // Estructura interna por proveedor:
  //   GEMINI   → { "apiKey": "...", "model": "gemini-2.5-flash" }
  //   CHATGPT  → { "apiKey": "...", "model": "gpt-4o-mini", "organizationId": "org_..." }
  //   CLAUDE   → { "apiKey": "...", "model": "claude-sonnet-4-6" }
  // Nunca se almacena en texto plano.
  encryptedApiConfig String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LlmProvider {
  GEMINI
  CHATGPT
  CLAUDE
  NONE
}

// -----------------------------------------------------------------------------
// 📱 CANAL WHATSAPP: CONFIGURACIÓN POR CLÍNICA
// Almacena las credenciales de la WhatsApp Business API (Meta Graph) que cada
// clínica obtiene de su panel de Meta for Developers.
// El access token NUNCA se guarda en texto plano: se encripta con AES-256-GCM.
// -----------------------------------------------------------------------------
model WhatsappAccountConfig {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // ID interno que Meta asigna a la línea telefónica (15–17 dígitos).
  // ÚNICO en toda la plataforma: es la llave que usa el webhook entrante
  // para enrutar mensajes al tenant correcto.
  phoneNumberId String? @unique

  // ID de la WhatsApp Business Account (WABA). Informativo.
  businessAccountId String?

  // Número de display (ej. "+57 300 1234567"). Solo para mostrar al usuario.
  displayPhoneNumber String?

  // Token elegido por la clínica para validar el webhook GET de Meta.
  // ÚNICO porque cuando Meta llama a verificar, sólo conocemos este token
  // y debemos identificar a qué clínica pertenece.
  verifyToken String? @unique

  // Permanent Access Token cifrado (AES-256-GCM). Empieza por "EAA…" en claro.
  encryptedAccessToken String? @db.Text

  // false hasta que la clínica termine de configurar y validar la conexión.
  isActive Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// 🔐 AUTH & CORE USER (Mínimo necesario para login)
// -----------------------------------------------------------------------------
model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  role     Role   @default(PATIENT)

  // Relaciones 1:1 con Perfiles Opcionales según el Rol
  patientProfile PatientProfile?
  doctorProfile  DoctorProfile?
  agentProfile   AgentProfile?

  // Relación con Logs de Auditoría ("Caja Negra")
  interactionLogs InteractionLog[]

  // Tickets de soporte que reportó este usuario
  supportTickets SupportTicket[]

  // 🏢 TENANT ISOLATION
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// 1. Catálogo de Aseguradoras (NUEVO)
// -----------------------------------------------------------------------------
model Eps {
  id       String  @id @default(uuid())
  name     String  @unique // Ej: 'Sura', 'Sanitas'
  nit      String? @unique
  isActive Boolean @default(true) // Para encender/apagar convenios

  // Relaciones
  patients        PatientProfile[] // Pacientes afiliados a esta EPS
  slots           ScheduleSlot[] // Cupos de agenda EXCLUSIVOS para esta EPS
  appointments    Appointment[] // Historial de citas facturadas por esta EPS
  agents          AgentProfile[] // Agentes limitados a agendar paciente de esta EPS
  waitlistEntries WaitlistEntry[]

  // 🏢 TENANT ISOLATION
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// 2. Catálogo de Servicios / Especialidades (NUEVO)
// -----------------------------------------------------------------------------
model MedicalService {
  id       String  @id @default(uuid())
  name     String  @unique // Ej: 'Odontología', 'Medicina General'
  isActive Boolean @default(true)

  // Relaciones
  doctors         DoctorProfile[] // Qué doctores prestan este servicio
  slots           ScheduleSlot[] // Agenda disponible para este servicio
  waitlistEntries WaitlistEntry[]

  // 🏢 TENANT ISOLATION
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// 🏥 PATIENT PROFILE (Datos Médicos y Contacto)
// -----------------------------------------------------------------------------
model PatientProfile {
  id String @id @default(uuid())

  // Identificadores Sociales (Indexados para el Bot)
  facebookId String? @unique
  whatsappId String?

  cedula      String    @unique
  fullName    String
  dateOfBirth DateTime?
  gender      String? // Ej: 'M', 'F', 'Other'
  address     String?

  // 🔌 CONEXIÓN EPS: El paciente declara su EPS base
  epsId String?
  eps   Eps?    @relation(fields: [epsId], references: [id])

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  appointments     Appointment[]
  clinicalRecords  ClinicalRecord[]
  informedConsents InformedConsent[]
  waitlistEntries  WaitlistEntry[]
  chatSurveys      ChatSurvey[]

  // 🏢 TENANT ISOLATION
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([whatsappId])
}

// -----------------------------------------------------------------------------
// 🩺 DOCTOR PROFILE (Datos Profesionales Médicos)
// -----------------------------------------------------------------------------
model DoctorProfile {
  id String @id @default(uuid())

  cedula         String  @unique
  fullName       String
  medicalLicense String? @unique // Tarjeta Profesional
  phone          String?
  isActive       Boolean @default(true)

  // 🔌 CONEXIÓN SERVICIO: La especialidad deja de ser String libre
  serviceId String?
  service   MedicalService? @relation(fields: [serviceId], references: [id])

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relación con el motor de turnos
  slots           ScheduleSlot[]
  agents          AgentProfile[] // Agentes limitados a gestionar la agenda de este doctor
  clinicalRecords ClinicalRecord[]
  addendums       Addendum[]
  waitlistEntries WaitlistEntry[] // Pacientes en lista de espera que pidieron a este médico

  // 🏢 TENANT ISOLATION
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// 3. Agenda Física de Disponibilidad (NUEVO MOTOR)
// -----------------------------------------------------------------------------
model ScheduleSlot {
  id String @id @default(uuid())

  startTime   DateTime
  endTime     DateTime
  isAvailable Boolean  @default(true)

  // Quién atiende en este bloque
  doctorId String
  doctor   DoctorProfile @relation(fields: [doctorId], references: [id])

  // Qué servicio se está prestando
  serviceId String
  service   MedicalService @relation(fields: [serviceId], references: [id])

  // Opcional: ¿Este hueco es exclusivo para pacientes de una EPS en particular?
  allowedEpsId String?
  allowedEps   Eps?    @relation(fields: [allowedEpsId], references: [id])

  // Relación 1:1 -> Si se ocupa, aquí está la cita. (Si es null, está libre)
  appointment Appointment?

  // 🏢 TENANT ISOLATION
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // No podemos tener slots duplicados para el mismo médico a la misma hora exacta
  @@unique([doctorId, startTime, endTime])
}

// -----------------------------------------------------------------------------
// 📅 APPOINTMENTS (Citas Médicas Evolucionada a HIS)
// -----------------------------------------------------------------------------
model Appointment {
  id               String            @id @default(uuid())
  status           AppointmentStatus @default(SCHEDULED)
  attendanceStatus AttendanceStatus  @default(PENDING) // NUEVO: Control de asistencia
  reason           String?

  // 🔌 CONEXIÓN AL SLOT: Ya no guardamos la 'fecha', apuntamos al slot real preconstruido.
  scheduleSlotId String       @unique
  scheduleSlot   ScheduleSlot @relation(fields: [scheduleSlotId], references: [id])

  // A quién se atiende
  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id])

  // 🔌 CONEXIÓN EPS FACTURACIÓN: Qué EPS autorizó y cubrirá este costo.
  epsId String?
  eps   Eps?    @relation(fields: [epsId], references: [id])

  // 🔌 EHR: Historia clínica asociada a esta cita específica. (1:1 opcional hasta que se crea)
  clinicalRecord ClinicalRecord?

  // 🏢 TENANT ISOLATION
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // ⏰ RECORDATORIO ENVIADO — idempotencia del cron de recordatorios.
  // NULL = nunca se ha enviado recordatorio para esta cita.
  // DateTime = momento UTC en que el cron disparó el WhatsApp con éxito.
  reminderSentAt DateTime?

  metaLog   Json?
  createdAt DateTime          @default(now())
  origin    AppointmentOrigin @default(WHATSAPP)
}

enum AppointmentOrigin {
  MANUAL
  WHATSAPP
}

enum Role {
  PATIENT
  DOCTOR
  ORG_ADMIN
  SUPER_ADMIN
  BOOKING_AGENT
  GENERAL_OBSERVER
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

// -----------------------------------------------------------------------------
// 🕵️ AUDITORÍA "CAJA NEGRA" (Logs de Chatbot y Demandas Fallidas)
// -----------------------------------------------------------------------------
model InteractionLog {
  id            String  @id @default(uuid())
  whatsappId    String // Identificador de WhatsApp/Facebook del remitente
  status        String // Ej: "SUCCESS", "FAILED", "ABANDONED"
  failureReason String? // Ej: "UNINTELLIGIBLE_AUDIO", "SERVICE_NOT_FOUND", "NO_AGENDA"

  // El rastro de la conversación para recuperación manual
  userMessage String? // Lo que transcribió Gemini o escribió el usuario
  botReply    String? // Lo que Vicente le contestó

  // 🔥 Superpoder NoSQL dentro de Postgres
  metadata Json? // Guarda info inferida (EPS, servicios) para Business Intelligence

  createdAt DateTime @default(now())

  // Relación opcional por si el usuario que falla ya tiene un PatientProfile/User
  patientId String?
  patient   User?   @relation(fields: [patientId], references: [id])

  // 🏢 TENANT ISOLATION
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  contactedAt  DateTime? // Cuándo el funcionario contactó al paciente
  contactedBy  String? // Email/nombre del funcionario que contactó
  contactNotes String?   @db.Text // Resultado del contacto
}

// -----------------------------------------------------------------------------
// 🏢 AGENT PROFILE (Agendador Humano con Scopes)
// -----------------------------------------------------------------------------
model AgentProfile {
  id String @id @default(uuid())

  fullName String
  phone    String?
  isActive Boolean @default(true)

  // 🔌 SCOPE: ¿Este Agente está limitado a atender pacientes de una EPS específica?
  epsId String?
  eps   Eps?    @relation(fields: [epsId], references: [id])

  // 🔌 SCOPE: ¿Este Agente está limitado a agendar citas de un Doctor en particular?
  doctorId String?
  doctor   DoctorProfile? @relation(fields: [doctorId], references: [id])

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 🏢 TENANT ISOLATION
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// 📋 ELECTRONIC HEALTH RECORD (EHR - Historia Clínica Electrónica)
// -----------------------------------------------------------------------------
model ClinicalRecord {
  id String @id @default(uuid())

  // Motivo de Consulta y Anamnesis
  chiefComplaint String @db.Text
  currentIllness String @db.Text

  // Examen Físico y Notas
  physicalExam   String? @db.Text
  evolutionNotes String? @db.Text

  // Relaciones
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id])

  doctorId String
  doctor   DoctorProfile @relation(fields: [doctorId], references: [id])

  // Componentes de la HC
  vitalSigns    VitalSigns?
  diagnoses     Diagnosis[]
  prescriptions MedicalPrescription[]

  // 🏢 TENANT ISOLATION
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  status       RecordStatus @default(DRAFT)
  recordNumber Int          @default(autoincrement())

  signature DigitalSignature?
  addendums Addendum[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VitalSigns {
  id String @id @default(uuid())

  bloodPressure String? // Ej: "120/80"
  heartRate     Int? // lpm
  temperature   Float? // °C
  weight        Float? // kg
  height        Float? // cm
  oxygenSat     Int? // %

  clinicalRecordId String         @unique
  clinicalRecord   ClinicalRecord @relation(fields: [clinicalRecordId], references: [id], onDelete: Cascade)
}

model Diagnosis {
  id String @id @default(uuid())

  code        String? // Para futuro soporte CIE-10 cruzado
  description String
  isMain      Boolean @default(true) // Diagnóstico Principal vs Secundario

  clinicalRecordId String
  clinicalRecord   ClinicalRecord @relation(fields: [clinicalRecordId], references: [id], onDelete: Cascade)
}

model MedicalPrescription {
  id String @id @default(uuid())

  medication String
  dose       String
  frequency  String
  duration   String
  notes      String?

  clinicalRecordId String
  clinicalRecord   ClinicalRecord @relation(fields: [clinicalRecordId], references: [id], onDelete: Cascade)
}

enum AttendanceStatus {
  PENDING
  ATTENDED
  NO_SHOW
}

// -----------------------------------------------------------------------------
// 🔐 LEGAL & COMPLIANCE (HealthTech Colombia)
// -----------------------------------------------------------------------------

enum RecordStatus {
  DRAFT
  SIGNED
  LOCKED
}

enum ConsentType {
  DATA_TREATMENT
  MEDICAL_PROCEDURE
}

enum ConsentStatus {
  ACCEPTED
  REVOKED
}

model DigitalSignature {
  id            String   @id @default(uuid())
  userId        String // El médico que firmó
  ipAddress     String?
  timestamp     DateTime @default(now())
  hashedContent String // Hash SHA-256 integrando historial y sello de tiempo

  // Relaciones (Debe pertenecer a un ClinicalRecord O a un Addendum)
  clinicalRecordId String?         @unique
  clinicalRecord   ClinicalRecord? @relation(fields: [clinicalRecordId], references: [id], onDelete: Cascade)

  addendumId String?   @unique
  addendum   Addendum? @relation(fields: [addendumId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Addendum {
  id      String @id @default(uuid())
  content String @db.Text // Nota aclaratoria

  doctorId String
  doctor   DoctorProfile @relation(fields: [doctorId], references: [id])

  clinicalRecordId String
  clinicalRecord   ClinicalRecord @relation(fields: [clinicalRecordId], references: [id], onDelete: Cascade)

  signature DigitalSignature?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InformedConsent {
  id        String        @id @default(uuid())
  type      ConsentType
  status    ConsentStatus @default(ACCEPTED)
  version   String // Versión de los términos de datos (ej: "v1.2")
  ipAddress String?
  userAgent String?

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// ⏳ LISTA DE ESPERA (WAITLIST)
// -----------------------------------------------------------------------------
model WaitlistEntry {
  id String @id @default(uuid())

  // Quién espera
  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // Qué busca
  serviceId String
  service   MedicalService @relation(fields: [serviceId], references: [id])

  // Filtro EPS (null = acepta cualquier slot universal)
  epsId String?
  eps   Eps?    @relation(fields: [epsId], references: [id])

  // Médico preferido (opcional): el paciente pidió un doctor específico.
  // null = acepta cualquier médico del servicio.
  preferredDoctorId String?
  preferredDoctor   DoctorProfile? @relation(fields: [preferredDoctorId], references: [id])

  // Estado de la entrada
  status     WaitlistStatus @default(WAITING)
  notifiedAt DateTime?
  expiresAt  DateTime?

  // Canal de contacto
  whatsappId String

  // Datos del slot pendiente cuando status = NOTIFIED
  // Estructura: { pendingSlotId, doctorName, slotDate }
  metadata Json?

  // 🏢 TENANT ISOLATION
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, serviceId, status])
  @@index([whatsappId, status])
  @@index([preferredDoctorId])
}

enum WaitlistStatus {
  WAITING // Esperando que se libere un cupo
  NOTIFIED // Le avisamos, esperando confirmación SI/NO
  CONFIRMED // Tomó el cupo (se convirtió en Appointment)
  EXPIRED // No respondió en 30 minutos
  CANCELLED // Salió voluntariamente o rechazó el cupo
}

// -----------------------------------------------------------------------------
// 🛟 HELP DESK / SOPORTE DE TICKETS INTERNO
// -----------------------------------------------------------------------------
model SupportTicket {
  id          String              @id @default(uuid())
  title       String
  description String              @db.Text
  status      SupportTicketStatus @default(OPEN)

  // Marcas temporales del ciclo de vida del ticket
  startedAt  DateTime?
  resolvedAt DateTime?

  // Nota/Respuesta del equipo de soporte (Super Admin)
  resolutionNote String? @db.Text

  // Quién reporta
  reporterId String
  reporter   User   @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  // 🏢 TENANT ISOLATION (clínica del reportante)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([reporterId, status])
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

// -----------------------------------------------------------------------------
// 🩻 SYSTEM LOG — Auditoría y trazabilidad centralizada (cross-tenant)
// Diseñado para crecer mucho. Solo visible para SUPER_ADMIN en el dashboard.
// -----------------------------------------------------------------------------
model SystemLog {
  id      String   @id @default(uuid())
  level   LogLevel
  action  String // Ej: 'USER_LOGIN', 'DOCTOR_DELETED', 'UNHANDLED_EXCEPTION'
  message String   @db.Text

  // Contexto rico: stack trace, body de la request, IP, headers, etc.
  metadata Json?

  userId         String?
  organizationId String?

  createdAt DateTime @default(now())

  // Índices críticos para listado y dashboard de "últimas 24h".
  @@index([createdAt])
  @@index([level, createdAt])
  @@index([action])
}

enum LogLevel {
  EVENT
  WARNING
  ERROR
}

// -----------------------------------------------------------------------------
// 🧾 GLOBAL AUDIT LOG — Bitácora inmutable a nivel plataforma (Super Admin)
//
// A diferencia de InteractionLog (que vive DENTRO del tenant y se borra con él)
// o de SystemLog (logging operacional), esta tabla es un registro legal
// append-only que debe SOBREVIVIR al borrado de una clínica.
//
// Por eso NO tiene llave foránea hacia Organization: guardamos organizationId
// y organizationName como escalares planos. Cuando el Super Admin purga una
// clínica, el FK desaparecería junto con la org; aquí, en cambio, queda la
// evidencia inmutable de quién purgó qué, cuándo y desde dónde.
// -----------------------------------------------------------------------------
model GlobalAuditLog {
  id      String            @id @default(uuid())
  action  GlobalAuditAction
  // Texto humano-legible del evento (lo que se muestra en el dashboard legal).
  message String            @db.Text

  // Actor que ejecutó la acción (no es FK: el actor podría ser eliminado luego).
  actorId    String?
  actorEmail String?

  // Objetivo de la acción. Escalares planos a propósito (sin relación) para
  // que la entrada sobreviva al hard delete del tenant.
  organizationId   String?
  organizationName String?

  // Trazabilidad de la request (IP, user agent) y conteos purgados, etc.
  ipAddress String?
  metadata  Json?

  // Inmutable por convención: sólo se inserta, nunca se actualiza ni borra.
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([organizationId])
}

enum GlobalAuditAction {
  ORGANIZATION_PURGED
  ORGANIZATION_CREATED
  ORGANIZATION_SUSPENDED
}

// -----------------------------------------------------------------------------
// ⭐ ENCUESTA DE SATISFACCIÓN POST-CHAT (CSAT)
//
// Al cerrar CUALQUIER flujo conversacional (cita agendada, ingreso a lista de
// espera, error técnico o cierre por insultos) el bot genera un registro aquí
// y envía por WhatsApp un enlace ÚNICO de un solo uso: https://.../encuesta/{id}.
//
// Seguridad: el `id` (UUID) ES el token del enlace. La página web sólo lo
// renderiza si isUsed == false y expiresAt > now(); de lo contrario redirige al
// Home. El POST de calificación vuelve a verificar ambas condiciones (regla de
// oro) y marca isUsed = true para que el enlace no se pueda reutilizar.
// -----------------------------------------------------------------------------
model ChatSurvey {
  // El UUID es a la vez la PK y el token público del enlace.
  id String @id @default(uuid())

  // 👤 A quién se le envió. Opcional: en cierres por insulto o error técnico
  // puede que el paciente nunca llegara a identificarse con su cédula.
  patientId String?
  patient   PatientProfile? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  // 🏢 TENANT ISOLATION
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // 🤖 Contexto auto-llenado por el bot al cerrar el flujo.
  chatSummary      String?          @db.Text
  resolutionStatus ResolutionStatus

  // ⭐ Llenado por el usuario en la web. null hasta que califica.
  rating   Int? // 1 a 5
  feedback String? @db.Text

  // 🔐 Seguridad del enlace de un solo uso.
  isUsed    Boolean  @default(false)
  expiresAt DateTime // Típicamente now() + 24h

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // El cron/limpieza y la búsqueda del token se apoyan en estos índices.
  @@index([organizationId, createdAt])
  @@index([isUsed, expiresAt])
}

enum ResolutionStatus {
  BOOKED // El paciente agendó su cita con éxito
  QUEUED // El paciente quedó en lista de espera
  BLOCKED_INSULT // La sesión se cerró por lenguaje abusivo
  SYSTEM_ERROR // Cierre por error técnico / exceso de reintentos
}

// -----------------------------------------------------------------------------
// 📡 MONITOR DE SERVICIOS EXTERNOS (Google / Meta) — incidentes
// -----------------------------------------------------------------------------
// El monitor de fondo (MonitorCron, MODO A) NO guarda cada check: solo escribe
// una fila cuando un servicio TRANSICIONA de UP a DOWN/DEGRADED (apertura) y la
// cierra (resolvedAt) cuando se recupera. Cada fila = un incidente completo.
// El monitoreo en vivo (MODO B) es 100% efímero y NUNCA toca esta tabla.
model ServiceIncident {
  id         String @id @default(uuid())
  serviceKey String // 'gemini', 'tts', 'meta'
  status     String // 'DOWN' o 'DEGRADED' (nunca UP — solo guardamos fallos)

  // Datos del primer check fallido (apertura del incidente).
  startedAt    DateTime @default(now())
  errorMessage String?  @db.Text
  errorCode    String? // 'TIMEOUT', 'AUTH', '5XX', etc. (para agrupar)
  httpStatus   Int?
  latencyMs    Int? // latencia del check que disparó el incidente

  // Cierre del incidente (cuando el servicio se recupera). null = aún abierto.
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serviceKey, startedAt])
  @@index([resolvedAt, startedAt])
  @@index([startedAt])
}
