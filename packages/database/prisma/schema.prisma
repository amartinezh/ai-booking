// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// 🏢 MULTI-TENANT: ORGANIZACIÓN (CLÍNICA/HOSPITAL)
// -----------------------------------------------------------------------------
model Organization {
  id              String  @id @default(uuid())
  name            String  @unique
  isActive        Boolean @default(true)
  whatsappPhoneId String? @unique
  logoUrl         String?

  // Facturación Global Súper Admin
  monthlyFee      String?
  lastPaymentDate DateTime?
  autoSuspend     Boolean @default(false)

  // Relaciones Inversas (Todo el sistema)
  users           User[]
  eps             Eps[]
  medicalServices MedicalService[]
  slots           ScheduleSlot[]
  appointments    Appointment[]
  clinicalRecords ClinicalRecord[]
  patients        PatientProfile[]
  doctors         DoctorProfile[]
  interactionLogs InteractionLog[]
  agents          AgentProfile[]
  waitlistEntries WaitlistEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// 🔐 AUTH & CORE USER (Mínimo necesario para login)
// -----------------------------------------------------------------------------
model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  role     Role   @default(PATIENT)

  // Relaciones 1:1 con Perfiles Opcionales según el Rol
  patientProfile PatientProfile?
  doctorProfile  DoctorProfile?
  agentProfile   AgentProfile?

  // Relación con Logs de Auditoría ("Caja Negra")
  interactionLogs InteractionLog[]

  // 🏢 TENANT ISOLATION
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// 1. Catálogo de Aseguradoras (NUEVO)
// -----------------------------------------------------------------------------
model Eps {
  id       String  @id @default(uuid())
  name     String  @unique // Ej: 'Sura', 'Sanitas'
  nit      String? @unique
  isActive Boolean @default(true) // Para encender/apagar convenios

  // Relaciones
  patients     PatientProfile[] // Pacientes afiliados a esta EPS
  slots        ScheduleSlot[] // Cupos de agenda EXCLUSIVOS para esta EPS
  appointments Appointment[] // Historial de citas facturadas por esta EPS
  agents       AgentProfile[] // Agentes limitados a agendar paciente de esta EPS
  waitlistEntries WaitlistEntry[]

  // 🏢 TENANT ISOLATION
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// 2. Catálogo de Servicios / Especialidades (NUEVO)
// -----------------------------------------------------------------------------
model MedicalService {
  id       String  @id @default(uuid())
  name     String  @unique // Ej: 'Odontología', 'Medicina General'
  isActive Boolean @default(true)

  // Relaciones
  doctors DoctorProfile[] // Qué doctores prestan este servicio
  slots   ScheduleSlot[] // Agenda disponible para este servicio
  waitlistEntries WaitlistEntry[]

  // 🏢 TENANT ISOLATION
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// 🏥 PATIENT PROFILE (Datos Médicos y Contacto)
// -----------------------------------------------------------------------------
model PatientProfile {
  id String @id @default(uuid())

  // Identificadores Sociales (Indexados para el Bot)
  facebookId String? @unique
  whatsappId String? @unique

  cedula      String    @unique
  fullName    String
  dateOfBirth DateTime?
  gender      String? // Ej: 'M', 'F', 'Other'
  address     String?

  // 🔌 CONEXIÓN EPS: El paciente declara su EPS base
  epsId String?
  eps   Eps?    @relation(fields: [epsId], references: [id])

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  appointments     Appointment[]
  clinicalRecords  ClinicalRecord[]
  informedConsents InformedConsent[]
  waitlistEntries  WaitlistEntry[]

  // 🏢 TENANT ISOLATION
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// 🩺 DOCTOR PROFILE (Datos Profesionales Médicos)
// -----------------------------------------------------------------------------
model DoctorProfile {
  id String @id @default(uuid())

  cedula         String  @unique
  fullName       String
  medicalLicense String? @unique // Tarjeta Profesional
  phone          String?
  isActive       Boolean @default(true)

  // 🔌 CONEXIÓN SERVICIO: La especialidad deja de ser String libre
  serviceId String?
  service   MedicalService? @relation(fields: [serviceId], references: [id])

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relación con el motor de turnos
  slots           ScheduleSlot[]
  agents          AgentProfile[] // Agentes limitados a gestionar la agenda de este doctor
  clinicalRecords ClinicalRecord[]
  addendums       Addendum[]

  // 🏢 TENANT ISOLATION
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// 3. Agenda Física de Disponibilidad (NUEVO MOTOR)
// -----------------------------------------------------------------------------
model ScheduleSlot {
  id String @id @default(uuid())

  startTime   DateTime
  endTime     DateTime
  isAvailable Boolean  @default(true)

  // Quién atiende en este bloque
  doctorId String
  doctor   DoctorProfile @relation(fields: [doctorId], references: [id])

  // Qué servicio se está prestando
  serviceId String
  service   MedicalService @relation(fields: [serviceId], references: [id])

  // Opcional: ¿Este hueco es exclusivo para pacientes de una EPS en particular?
  allowedEpsId String?
  allowedEps   Eps?    @relation(fields: [allowedEpsId], references: [id])

  // Relación 1:1 -> Si se ocupa, aquí está la cita. (Si es null, está libre)
  appointment Appointment?

  // 🏢 TENANT ISOLATION
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // No podemos tener slots duplicados para el mismo médico a la misma hora exacta
  @@unique([doctorId, startTime, endTime])
}

// -----------------------------------------------------------------------------
// 📅 APPOINTMENTS (Citas Médicas Evolucionada a HIS)
// -----------------------------------------------------------------------------
model Appointment {
  id               String            @id @default(uuid())
  status           AppointmentStatus @default(SCHEDULED)
  attendanceStatus AttendanceStatus  @default(PENDING) // NUEVO: Control de asistencia
  reason           String?

  // 🔌 CONEXIÓN AL SLOT: Ya no guardamos la 'fecha', apuntamos al slot real preconstruido.
  scheduleSlotId String       @unique
  scheduleSlot   ScheduleSlot @relation(fields: [scheduleSlotId], references: [id])

  // A quién se atiende
  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id])

  // 🔌 CONEXIÓN EPS FACTURACIÓN: Qué EPS autorizó y cubrirá este costo.
  epsId String?
  eps   Eps?    @relation(fields: [epsId], references: [id])

  // 🔌 EHR: Historia clínica asociada a esta cita específica. (1:1 opcional hasta que se crea)
  clinicalRecord ClinicalRecord?

  // 🏢 TENANT ISOLATION
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  metaLog   Json?
  createdAt DateTime          @default(now())
  origin    AppointmentOrigin @default(WHATSAPP)
}

enum AppointmentOrigin {
  MANUAL
  WHATSAPP
}

enum Role {
  PATIENT
  DOCTOR
  ORG_ADMIN
  SUPER_ADMIN
  BOOKING_AGENT
  GENERAL_OBSERVER
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

// -----------------------------------------------------------------------------
// 🕵️ AUDITORÍA "CAJA NEGRA" (Logs de Chatbot y Demandas Fallidas)
// -----------------------------------------------------------------------------
model InteractionLog {
  id            String  @id @default(uuid())
  whatsappId    String // Identificador de WhatsApp/Facebook del remitente
  status        String // Ej: "SUCCESS", "FAILED", "ABANDONED"
  failureReason String? // Ej: "UNINTELLIGIBLE_AUDIO", "SERVICE_NOT_FOUND", "NO_AGENDA"

  // El rastro de la conversación para recuperación manual
  userMessage String? // Lo que transcribió Gemini o escribió el usuario
  botReply    String? // Lo que Vicente le contestó

  // 🔥 Superpoder NoSQL dentro de Postgres
  metadata Json? // Guarda info inferida (EPS, servicios) para Business Intelligence

  createdAt DateTime @default(now())

  // Relación opcional por si el usuario que falla ya tiene un PatientProfile/User
  patientId String?
  patient   User?   @relation(fields: [patientId], references: [id])

  // 🏢 TENANT ISOLATION
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
}

// -----------------------------------------------------------------------------
// 🏢 AGENT PROFILE (Agendador Humano con Scopes)
// -----------------------------------------------------------------------------
model AgentProfile {
  id String @id @default(uuid())

  fullName String
  phone    String?
  isActive Boolean @default(true)

  // 🔌 SCOPE: ¿Este Agente está limitado a atender pacientes de una EPS específica?
  epsId String?
  eps   Eps?    @relation(fields: [epsId], references: [id])

  // 🔌 SCOPE: ¿Este Agente está limitado a agendar citas de un Doctor en particular?
  doctorId String?
  doctor   DoctorProfile? @relation(fields: [doctorId], references: [id])

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 🏢 TENANT ISOLATION
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// 📋 ELECTRONIC HEALTH RECORD (EHR - Historia Clínica Electrónica)
// -----------------------------------------------------------------------------
model ClinicalRecord {
  id String @id @default(uuid())

  // Motivo de Consulta y Anamnesis
  chiefComplaint String @db.Text
  currentIllness String @db.Text

  // Examen Físico y Notas
  physicalExam   String? @db.Text
  evolutionNotes String? @db.Text

  // Relaciones
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id])

  doctorId String
  doctor   DoctorProfile @relation(fields: [doctorId], references: [id])

  // Componentes de la HC
  vitalSigns    VitalSigns?
  diagnoses     Diagnosis[]
  prescriptions MedicalPrescription[]

  // 🏢 TENANT ISOLATION
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  status       RecordStatus @default(DRAFT)
  recordNumber Int          @default(autoincrement())

  signature DigitalSignature?
  addendums Addendum[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VitalSigns {
  id String @id @default(uuid())

  bloodPressure String? // Ej: "120/80"
  heartRate     Int? // lpm
  temperature   Float? // °C
  weight        Float? // kg
  height        Float? // cm
  oxygenSat     Int? // %

  clinicalRecordId String         @unique
  clinicalRecord   ClinicalRecord @relation(fields: [clinicalRecordId], references: [id], onDelete: Cascade)
}

model Diagnosis {
  id String @id @default(uuid())

  code        String? // Para futuro soporte CIE-10 cruzado
  description String
  isMain      Boolean @default(true) // Diagnóstico Principal vs Secundario

  clinicalRecordId String
  clinicalRecord   ClinicalRecord @relation(fields: [clinicalRecordId], references: [id], onDelete: Cascade)
}

model MedicalPrescription {
  id String @id @default(uuid())

  medication String
  dose       String
  frequency  String
  duration   String
  notes      String?

  clinicalRecordId String
  clinicalRecord   ClinicalRecord @relation(fields: [clinicalRecordId], references: [id], onDelete: Cascade)
}

enum AttendanceStatus {
  PENDING
  ATTENDED
  NO_SHOW
}

// -----------------------------------------------------------------------------
// 🔐 LEGAL & COMPLIANCE (HealthTech Colombia)
// -----------------------------------------------------------------------------

enum RecordStatus {
  DRAFT
  SIGNED
  LOCKED
}

enum ConsentType {
  DATA_TREATMENT
  MEDICAL_PROCEDURE
}

enum ConsentStatus {
  ACCEPTED
  REVOKED
}

model DigitalSignature {
  id            String   @id @default(uuid())
  userId        String // El médico que firmó
  ipAddress     String?
  timestamp     DateTime @default(now())
  hashedContent String // Hash SHA-256 integrando historial y sello de tiempo

  // Relaciones (Debe pertenecer a un ClinicalRecord O a un Addendum)
  clinicalRecordId String?         @unique
  clinicalRecord   ClinicalRecord? @relation(fields: [clinicalRecordId], references: [id], onDelete: Cascade)

  addendumId String?   @unique
  addendum   Addendum? @relation(fields: [addendumId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Addendum {
  id      String @id @default(uuid())
  content String @db.Text // Nota aclaratoria

  doctorId String
  doctor   DoctorProfile @relation(fields: [doctorId], references: [id])

  clinicalRecordId String
  clinicalRecord   ClinicalRecord @relation(fields: [clinicalRecordId], references: [id], onDelete: Cascade)

  signature DigitalSignature?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InformedConsent {
  id        String        @id @default(uuid())
  type      ConsentType
  status    ConsentStatus @default(ACCEPTED)
  version   String // Versión de los términos de datos (ej: "v1.2")
  ipAddress String?
  userAgent String?

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// ⏳ LISTA DE ESPERA (WAITLIST)
// -----------------------------------------------------------------------------
model WaitlistEntry {
  id String @id @default(uuid())

  // Quién espera
  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // Qué busca
  serviceId String
  service   MedicalService @relation(fields: [serviceId], references: [id])

  // Filtro EPS (null = acepta cualquier slot universal)
  epsId String?
  eps   Eps?    @relation(fields: [epsId], references: [id])

  // Estado de la entrada
  status     WaitlistStatus @default(WAITING)
  notifiedAt DateTime?
  expiresAt  DateTime?

  // Canal de contacto
  whatsappId String

  // Datos del slot pendiente cuando status = NOTIFIED
  // Estructura: { pendingSlotId, doctorName, slotDate }
  metadata Json?

  // 🏢 TENANT ISOLATION
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, serviceId, status])
  @@index([whatsappId, status])
}

enum WaitlistStatus {
  WAITING    // Esperando que se libere un cupo
  NOTIFIED   // Le avisamos, esperando confirmación SI/NO
  CONFIRMED  // Tomó el cupo (se convirtió en Appointment)
  EXPIRED    // No respondió en 30 minutos
  CANCELLED  // Salió voluntariamente o rechazó el cupo
}
